{
  "name": "trustip-monorepo",
  "version": "1.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate-types": "tsx scripts/generate-types.ts",
    "deploy:contract": "tsx scripts/deploy-contract.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "verify:env:production": "tsx scripts/verify-env.ts --production",
    "verify:env:onchain": "tsx scripts/verify-env.ts --production --on-chain"
  },
  "devDependencies": {
    "turbo": "2.10.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^20.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
