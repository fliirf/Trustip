# App Config
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Stellar network
# NEXT_PUBLIC_STELLAR_NETWORK is used by the web/client app.
# STELLAR_NETWORK is used by the Node.js workers (no Next.js bundler).
# Keep both in sync (testnet | mainnet).
NEXT_PUBLIC_STELLAR_NETWORK=testnet
STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar assets and contracts
# For mainnet, NEXT_PUBLIC_USDC_ISSUER is REQUIRED (no fallback) and must be the
# real Circle USDC issuer: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# The value below is the Stellar testnet USDC issuer.
NEXT_PUBLIC_USDC_ASSET_CODE=USDC
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
NEXT_PUBLIC_USDC_CONTRACT_ID=replace-with-deployed-usdc-sac-contract-id
# Escrow contract id is public (client builds txs against it). Set both to the
# same deployed id; the deploy script prints it after `deploy-contract`.
NEXT_PUBLIC_SOROBAN_ESCROW_CONTRACT_ID=replace-with-deployed-escrow-contract-id
SOROBAN_ESCROW_CONTRACT_ID=replace-with-deployed-escrow-contract-id
SOROBAN_ADMIN_SECRET_KEY=replace-with-admin-secret-key-never-commit-real-value

# Deploy script (scripts/deploy-contract.ts) — Stellar CLI identity that
# deploys + initializes the escrow contract (also becomes the admin by default).
STELLAR_DEPLOY_IDENTITY=trustip-deployer
# Optional: override the admin address stored in the contract (default = the
# deploy identity's address).
SOROBAN_ADMIN_ADDRESS=

# Backend operator/admin signer (SERVER-ONLY — never NEXT_PUBLIC, never commit a
# real value). Signs escrow create_order (POST /api/escrows/create-order). Must be
# the deployed contract's admin secret. Fails closed if unset; refused on mainnet
# unless TRUSTIP_ALLOW_MAINNET_OPERATOR=true (an approved signer strategy). Either
# TRUSTIP_OPERATOR_SECRET_KEY or STELLAR_OPERATOR_SECRET_KEY is accepted.
TRUSTIP_OPERATOR_SECRET_KEY=replace-with-operator-admin-secret-key-never-commit
# STELLAR_OPERATOR_SECRET_KEY=
TRUSTIP_ALLOW_MAINNET_OPERATOR=false

# Payment backend (Phase 4.6): optional SERVER-ONLY HMAC secret. When set, submit
# requires a valid prepare attempt token. Recommended for production.
PAYMENT_ATTEMPT_SECRET=

# Checkout authorization (Phase 4.1.6 / 5.0): SERVER-ONLY HMAC secret for
# short-lived create-order tokens. REQUIRED to ISSUE guest checkout tokens
# (POST /api/checkout/token) — issuance fails closed without it. Also gates the
# guest path of POST /api/escrows/create-order: a guest must present a valid
# token bound to {orderId, buyerPublicKey, contractOrderId, network}; when unset,
# only an authenticated order owner (or admin) may create. Use >=32 random bytes.
# Never NEXT_PUBLIC, never commit a real value. Required for production guest
# checkout.
TRUSTIP_CHECKOUT_TOKEN_SECRET=

# Seller wallet-ownership challenges (Phase 7B): SERVER-ONLY HMAC secret for
# short-lived challenge tokens (POST /api/seller/wallets/challenge → verify).
# REQUIRED to verify seller wallets — issuance and verification fail closed
# without it, and `verified_at` can never be set. Use >=32 random bytes.
# Never NEXT_PUBLIC, never commit a real value.
TRUSTIP_WALLET_CHALLENGE_SECRET=

# Wallet config
NEXT_PUBLIC_ENABLE_FREIGHTER=true
NEXT_PUBLIC_ENABLE_XBULL=true

# Payout config
NEXT_PUBLIC_ENABLE_XLM_PAYOUT=false
NEXT_PUBLIC_ENABLE_MONEYGRAM_ROUTE=true
MONEYGRAM_PARTNER_API_URL=https://api.moneygram.com
MONEYGRAM_PARTNER_API_KEY=your-moneygram-key

# Binance guide/future
NEXT_PUBLIC_ENABLE_BINANCE_TOPUP_GUIDE=true
NEXT_PUBLIC_ENABLE_BINANCE_PAY=false
BINANCE_PAY_API_KEY=your-binance-pay-key
BINANCE_PAY_SECRET=your-binance-pay-secret

# Workers
ESCROW_INDEXER_INTERVAL_SECONDS=30
PAYOUT_SYNC_INTERVAL_SECONDS=60
JOB_SECRET=your-job-secret
