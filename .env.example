# Trustip v1.1 canonical environment
# Copy only the values needed by the target process. Never commit real secrets.

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.1.0

# Supabase (local defaults; keys come from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stellar network
# Next.js requires the public name; workers/deploy scripts require the server
# name. Production verification rejects missing or different values.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Circle USDC. The contract ID is the SAC derived from USDC + issuer + network.
# Mainnet issuer (public metadata):
# GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
NEXT_PUBLIC_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
NEXT_PUBLIC_USDC_CONTRACT_ID=
NEXT_PUBLIC_SOROBAN_ESCROW_CONTRACT_ID=

# Server-only operator signer. `env` is the only implemented strategy.
TRUSTIP_SIGNER_STRATEGY=env
TRUSTIP_OPERATOR_SECRET_KEY=
TRUSTIP_ALLOW_MAINNET_OPERATOR=false

# Server-only application secrets (minimum 32 characters in production)
PAYMENT_ATTEMPT_SECRET=
TRUSTIP_CHECKOUT_TOKEN_SECRET=
TRUSTIP_WALLET_CHALLENGE_SECRET=
TRUSTIP_SEP10_JWT_SECRET=

# Distributed production rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
TRUSTIP_TRUSTED_PROXY_HOPS=1
TRUSTIP_CLIENT_IP_HEADER=

# Optional SEP-24 anchor discovery. Testnet reference anchor shown for local QA.
NEXT_PUBLIC_ANCHOR_DOMAIN=testanchor.stellar.org

# Escrow event indexer
INDEXER_POLL_MS=30000
INDEXER_RECONCILE_EVERY=4
INDEXER_START_LOOKBACK=17280

# Disabled until their business flows are implemented
TRUSTIP_PAYOUT_WORKER_ENABLED=false
TRUSTIP_REFUND_WORKER_ENABLED=false

# Contract deployment (Stellar CLI identity name, never a secret seed)
STELLAR_DEPLOY_IDENTITY=trustip-deployer
